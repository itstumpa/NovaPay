# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://novapay:novapay123@localhost:5432/novapay_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Encryption (envelope encryption)
# Master Key: 32 bytes hex (openssl rand -hex 32)
MASTER_ENCRYPTION_KEY="your-32-byte-hex-master-key-here-change-me"
# Data Encryption Key: 32 bytes hex (openssl rand -hex 32)
DATA_ENCRYPTION_KEY="your-32-byte-hex-data-key-here-change-me"

# Super Admin Bootstrap
SUPER_ADMIN_EMAIL="superadmin@novapay.com"
SUPER_ADMIN_PASSWORD="SuperAdmin@123!"
SUPER_ADMIN_NAME="Nova Super Admin"

FX_PROVIDER_URL="https://api.exchangerate-api.com/v4/latest"
FX_QUOTE_TTL_SECONDS=60

# BullMQ
PAYROLL_QUEUE_CONCURRENCY=1
